#!/usr/bin/env python3
"""Diagnostic helper for checking response markers on the energie vergelijken page.

Usage:
    python script

This helper intentionally performs a live HTTP request when run directly.
"""

import requests


def main():
    url = 'https://www.mijnenergie.be/energie-vergelijken-3-resultaten-?Form=fe&e=elektriciteit&d=0&c=particulier&cp=1000&i2=0----3800-0-0-1----0----1-1%7C1%7C1%7C1-0%7C0%7C0%7C%7C0%21F%21A%21n%7C0%21F%21A%7C0%7C0%7C%7C%7C%7C%7C%21%7C%7C0%7C%7C0-0%7C0-0'
    t = requests.get(url, timeout=30).text
    print('__NEXT_DATA__', '__NEXT_DATA__' in t)
    print('next_f', 'self.__next_f.push' in t)
    print('article', '<article' in t, t.count('<article'))
    print('year_token', '/jaar' in t, t.count('/jaar'))
    print('resultaten', 'Resultaten' in t)
    print('json_script', '<script id="__NEXT_DATA__"' in t)


if __name__ == "__main__":
    main()
